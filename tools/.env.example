# Notion API Integration Key
# Create at: https://www.notion.so/my-integrations
# Make sure the integration has access to AI_ACCESS_ROOT page
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Root page ID — the AI_ACCESS_ROOT page in Notion
# Find it in the page URL: https://notion.so/AI-ACCESS-ROOT-<PAGE_ID>
# Format: with or without dashes
NOTION_ROOT_PAGE_ID=
