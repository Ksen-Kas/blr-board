# Same env vars as the Telegram bot — copy from bot's .env
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_CREDENTIALS_JSON_CONTENT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Optional
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TIMEZONE=Asia/Dubai
REMINDER_HOUR=10
REMINDER_MINUTE=0
CLIENT_SPACE_PATH=../CLIENT_SPACE

# App runtime
APP_ENV=production

# Access control (recommended for Railway)
API_ACCESS_USERNAME=your_username
API_ACCESS_PASSWORD=your_password
INTERNAL_API_KEY=your_internal_api_key

# Comma-separated frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173
