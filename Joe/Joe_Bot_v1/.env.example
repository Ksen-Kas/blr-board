# ─────────────────────────────────────
# Telegram
# ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=        # от @BotFather
TELEGRAM_CHAT_ID=          # ID чата (узнать через @userinfobot)

# ─────────────────────────────────────
# Claude API
# ─────────────────────────────────────
ANTHROPIC_API_KEY=         # https://console.anthropic.com/

# ─────────────────────────────────────
# Google Sheets
# ─────────────────────────────────────
GOOGLE_SHEET_ID=           # из URL таблицы: /d/{ID}/edit
GOOGLE_CREDENTIALS_JSON=./credentials.json   # путь к service account JSON

# ─────────────────────────────────────
# Настройки бота
# ─────────────────────────────────────
TIMEZONE=Asia/Dubai        # IANA timezone: Asia/Dubai (UTC+4), Europe/Helsinki и т.д.
REMINDER_HOUR=8            # час утренней рассылки (по TIMEZONE)
REMINDER_MINUTE=0
